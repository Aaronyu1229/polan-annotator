# Phase 6 — environment template for the VPS deployment.
# Copy to .env on the VPS and fill in real values. Never commit .env.

# ───────── App ─────────
# 對外網域；用於 OAuth callback、cookie domain、CORS 等。
APP_DOMAIN=annotate.dolcenforte.com
# Session 簽章用，建議 `python -c "import secrets; print(secrets.token_urlsafe(32))"`。
APP_SECRET_KEY=change-me-32-bytes-random
# 容器內 uvicorn 監聽 port；docker-compose 不對外發佈，由 nginx 反向代理。
APP_PORT=8000
# 部署環境標籤，用於 Sentry 等 tag。
APP_ENV=production

# ───────── OAuth (Google) ─────────
# 從 GCP Console → APIs & Services → Credentials 建立 OAuth 2.0 Client。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 必須完全等於 GCP 設定的 Authorized redirect URI。
OAUTH_REDIRECT_URI=https://annotate.dolcenforte.com/auth/callback

# ───────── Whitelist / annotator mapping ─────────
# 逗號分隔的 Gmail 白名單；不在這份名單的 email 不能登入。
ALLOWED_EMAILS=reborn.uidesigner@gmail.com,polanmusic2025@gmail.com
# JSON 字串：email → annotator_id；未列出的 email 預設取 @ 前段。
EMAIL_TO_ANNOTATOR_JSON={"reborn.uidesigner@gmail.com":"aaron","polanmusic2025@gmail.com":"amber"}
# 逗號分隔的 admin email；admin 才能上傳新音檔。
ADMIN_EMAILS=reborn.uidesigner@gmail.com,polanmusic2025@gmail.com

# ───────── Cloudflare R2 (Litestream backup) ─────────
# 建議 bucket 名：polan-annotator-backup
R2_BUCKET=polan-annotator-backup
# 形如 https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Litestream 透過 LITESTREAM_* 環境變數讀 R2 憑證；保持與上面一致。
LITESTREAM_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID}
LITESTREAM_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY}

# ───────── Sentry (optional) ─────────
# 留空即停用 error tracking；填入後 src/main.py 會自動初始化 SDK。
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
